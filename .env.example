# Supabase — use the service-role key (NOT the anon key) so RLS is bypassed
# only by the server-side proxy, never the browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# n8n approval webhook — the full URL that WF5/approval-action listens on.
N8N_WEBHOOK_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/approval-action

# Shared secret sent as X-Approval-Secret header so n8n can verify
# that the request came from your server, not a random browser.
# Generate with: openssl rand -hex 32
APPROVAL_SECRET=replace-with-a-random-secret

# Optional: restrict CORS to your Vercel domain.
# Defaults to * if unset.
ALLOWED_ORIGIN=https://your-project.vercel.app
